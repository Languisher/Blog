---
import CategoryList from '@/components/CategoryList.astro'
import TagPostTimeline from '@/components/TagPostTimeline.astro'
import { allLocales } from '@/config'
import { getLangFromLocale, getLangRouteParam } from '@/i18n/lang'
import { getCategoryPath, getLocalizedPath } from '@/i18n/path'
import Layout from '@/layouts/Layout.astro'
import { getAllCategoriesWithCount, getPosts } from '@/utils/content'

export async function getStaticPaths() {
  return allLocales.map(lang => ({
    params: { lang: getLangRouteParam(lang) },
  }))
}

const currentLang = getLangFromLocale(Astro.currentLocale)
const allCategories = await getAllCategoriesWithCount(currentLang)
const posts = (await getPosts(currentLang)).filter(post => post.data.category || post.id.includes('/'))
const categoryItems = allCategories.map(category => ({
  label: category.name,
  slug: category.slug,
  href: getCategoryPath(category.slug, currentLang),
  count: category.count,
  depth: category.depth,
  childSlugs: category.children.map(child => child.slug),
}))
---

<Layout>
  <!-- Decorative Line -->
  <div class="uno-decorative-line" />
  <!-- Category List -->
  <CategoryList
    items={categoryItems}
    allHref={getLocalizedPath('/categories/', currentLang)}
  />

  <!-- Posts List -->
  <div class="mt-10.5">
    <TagPostTimeline
      posts={posts}
      lang={currentLang}
    />
  </div>
</Layout>

---
import type { Language } from '@/i18n/config'
import TaxonomyList from '@/components/TaxonomyList.astro'
import { getLocalizedPath, getTagPath } from '@/i18n/path'

interface Props {
  tags: string[] | {
    name: string
    count: number
  }[]
  currentTag?: string
  lang: Language
}

const { tags, currentTag = '', lang } = Astro.props
const allTagsPath = getLocalizedPath('/tags/', lang)

const tagItems = tags.map((tag) => {
  const name = typeof tag === 'string' ? tag : tag.name
  const count = typeof tag === 'string' ? 1 : tag.count

  return {
    label: `#${name}`,
    href: currentTag === name ? allTagsPath : getTagPath(name, lang),
    count,
    active: currentTag === name,
  }
})
---

<TaxonomyList
  items={tagItems}
  allHref={allTagsPath}
  currentKey={currentTag}
/>

---
interface TaxonomyItem {
  label: string
  href: string
  count: number
  depth?: number
  active?: boolean
}

interface Props {
  items: TaxonomyItem[]
  allHref: string
  allLabel?: string
  currentKey?: string
}

const { items, allHref, allLabel = 'All', currentKey = '' } = Astro.props
const maxCount = Math.max(1, ...items.map(item => item.count))

function getIntensity(count: number) {
  return 0.08 + (count / maxCount) * 0.18
}
---

<div class="no-heti taxonomy-list flex flex-wrap items-center gap-x-3 gap-y-3.2">
  <a
    href={allHref}
    class:list={[
      'taxonomy-button',
      currentKey === '' ? 'is-active' : '',
    ]}
    style={`--taxonomy-intensity: ${getIntensity(maxCount)}; --taxonomy-depth: 0;`}
  >
    {allLabel}
  </a>

  {items.map(item => (
    <a
      href={item.href}
      class:list={[
        'taxonomy-button',
        item.active ? 'is-active' : '',
      ]}
      style={`--taxonomy-intensity: ${getIntensity(item.count)}; --taxonomy-depth: ${item.depth ?? 0};`}
    >
      {item.label}
      <span class="taxonomy-count">{item.count}</span>
    </a>
  ))}
</div>

<style>
  .taxonomy-button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.55rem;
    margin-left: calc(var(--taxonomy-depth, 0) * 0.85rem);
    border: 1px solid oklch(var(--un-preset-theme-colors-secondary) / 0.1);
    border-bottom-color: oklch(var(--un-preset-theme-colors-secondary) / 0.58);
    border-bottom-width: 2px;
    border-radius: 0.32rem;
    padding: 0.55rem 1.1rem;
    background:
      linear-gradient(
        180deg,
        oklch(var(--un-preset-theme-colors-note) / var(--taxonomy-intensity, 0.14)),
        oklch(var(--un-preset-theme-colors-secondary) / calc(var(--taxonomy-intensity, 0.14) * 0.52))
      );
    color: oklch(var(--un-preset-theme-colors-secondary) / 0.74);
    font-weight: 650;
    line-height: 1;
    box-shadow: inset 0 1px 0 oklch(var(--un-preset-theme-colors-background) / 0.75);
    transition:
      border-color 0.16s ease-out,
      color 0.16s ease-out,
      transform 0.16s ease-out,
      background-color 0.16s ease-out;
  }

  .taxonomy-button:hover,
  .taxonomy-button.is-active {
    border-color: oklch(var(--un-preset-theme-colors-primary) / 0.24);
    border-bottom-color: oklch(var(--un-preset-theme-colors-primary) / 0.72);
    color: oklch(var(--un-preset-theme-colors-primary));
    transform: translateY(-1px);
  }

  .taxonomy-count {
    color: oklch(var(--un-preset-theme-colors-secondary) / 0.48);
    font-size: 0.78em;
    font-weight: 700;
  }
</style>

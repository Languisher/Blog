---
interface TaxonomyItem {
  label: string
  href: string
  count: number
  depth?: number
  active?: boolean
}

interface Props {
  items: TaxonomyItem[]
  allHref: string
  allLabel?: string
  currentKey?: string
}

const { items, allHref, allLabel = 'All', currentKey = '' } = Astro.props
const maxCount = Math.max(1, ...items.map(item => item.count))

function getIntensity(count: number) {
  return 0.07 + (count / maxCount) * 0.13
}
---

<div class="no-heti taxonomy-list">
  <a
    href={allHref}
    class:list={[
      'taxonomy-button',
      'taxonomy-button-all',
      currentKey === '' ? 'is-active' : '',
    ]}
    style={`--taxonomy-intensity: ${getIntensity(maxCount)}; --taxonomy-depth: 0;`}
  >
    {allLabel}
  </a>

  <div class="taxonomy-tree">
    {items.map(item => (
      <a
        href={item.href}
        class:list={[
          'taxonomy-button',
          item.active ? 'is-active' : '',
        ]}
        style={`--taxonomy-intensity: ${getIntensity(item.count)}; --taxonomy-depth: ${item.depth ?? 0};`}
      >
        {item.label}
        <span class="taxonomy-count">{item.count}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .taxonomy-list {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.72rem;
  }

  .taxonomy-tree {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.52rem;
  }

  .taxonomy-button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 1.7rem;
    margin-left: calc(var(--taxonomy-depth, 0) * 1.15rem);
    border: 1px solid transparent;
    border-radius: 0.55rem;
    padding: 0.42rem 1.08rem;
    background: oklch(var(--un-preset-theme-colors-secondary) / var(--taxonomy-intensity, 0.12));
    color: oklch(var(--un-preset-theme-colors-secondary) / 0.86);
    font-weight: 650;
    line-height: 1;
    transition:
      border-color 0.16s ease-out,
      color 0.16s ease-out,
      background-color 0.16s ease-out;
  }

  .taxonomy-button:not(.taxonomy-button-all) {
    position: relative;
  }

  .taxonomy-button:not(.taxonomy-button-all)::before {
    content: '';
    position: absolute;
    left: calc(var(--taxonomy-depth, 0) * -1.15rem + 0.42rem);
    top: 50%;
    width: calc(var(--taxonomy-depth, 0) * 0.72rem);
    height: 1px;
    background: oklch(var(--un-preset-theme-colors-secondary) / 0.24);
    transform: translateY(-50%);
  }

  .taxonomy-button[style*="--taxonomy-depth: 0"]::before {
    display: none;
  }

  .taxonomy-button:hover {
    background: oklch(var(--un-preset-theme-colors-secondary) / calc(var(--taxonomy-intensity, 0.12) + 0.04));
    color: oklch(var(--un-preset-theme-colors-secondary) / 0.98);
  }

  .taxonomy-button.is-active {
    border-color: oklch(var(--un-preset-theme-colors-note) / 0.68);
    background: oklch(var(--un-preset-theme-colors-note) / 0.16);
    color: oklch(var(--un-preset-theme-colors-primary));
  }

  .taxonomy-count {
    color: currentColor;
    font-size: 0.78em;
    font-weight: 700;
    opacity: 0.58;
  }
</style>
